generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  DEVELOPER
  TESTER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  FEATURE
  BUG
  IMPROVEMENT
  TASK
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(DEVELOPER)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("AssignedTasks")
  createdTasks       Task[]          @relation("CreatedTasks")
  comments           Comment[]
  activityLogs       ActivityLog[]
  notifications      Notification[]
  invitations        Invitation[]
  timeEntries        TimeEntry[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  key         String        @unique
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     ProjectMember[]
  tasks       Task[]
  sprints     Sprint[]
  activityLogs ActivityLog[]
  labels       Label[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      Role     @default(DEVELOPER)
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(TASK)
  order       Int          @default(0)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId   String
  assigneeId  String?
  creatorId   String?
  sprintId    String?

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?    @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User?    @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: SetNull)
  sprint   Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  comments     Comment[]
  activityLogs ActivityLog[]
  attachments  Attachment[]
  labels       TaskLabel[]
  timeEntries  TimeEntry[]
  blockedBy    TaskDependency[] @relation("BlockedTask")
  blocks       TaskDependency[] @relation("BlockerTask")

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([sprintId])
  @@map("tasks")
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNING)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId])
  @@map("sprints")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())

  userId    String
  projectId String?
  taskId    String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@map("activity_logs")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  COMMENT_ADDED
  PROJECT_ADDED
  SPRINT_STARTED
  MENTIONED
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  fileSize  Int
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  taskId    String
  uploadedBy String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("attachments")
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks TaskLabel[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("labels")
}

model TaskLabel {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("task_labels")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(DEVELOPER)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  invitedById String
  invitedBy   User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@map("invitations")
}

model TaskDependency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockedTaskId String
  blockerTaskId String

  blockedTask Task @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  blockerTask Task @relation("BlockerTask", fields: [blockerTaskId], references: [id], onDelete: Cascade)

  @@unique([blockedTaskId, blockerTaskId])
  @@index([blockedTaskId])
  @@index([blockerTaskId])
  @@map("task_dependencies")
}

model TimeEntry {
  id          String   @id @default(cuid())
  minutes     Int
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("time_entries")
}
